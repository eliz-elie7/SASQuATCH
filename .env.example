# ==========================================
# CONFIGURATION DE LA BASE DE DONNÉES (POSTGRESQL)
# ==========================================
# Identifiants pour se connecter à la base de données PostgreSQL
POSTGRES_USER=sasquatch_dev_user
POSTGRES_PASSWORD=votre_mot_de_passe_securise_ici
POSTGRES_DB=sasquatch_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ==========================================
# SÉCURITÉ ET CRYPTOGRAPHIE
# ==========================================
# Clé maître pour le chiffrement symétrique AES-256 des données personnelles (noms, prénoms, emails)
# Doit impérativement être une chaîne aléatoire de 32 octets encodée (ex: base64)
AES_MASTER_KEY=votre_cle_aes_256_secrete_ici

# Clé secrète générale pour l'application (FastAPI), utilisée par exemple pour signer les tokens de connexion (JWT)
API_SECRET_KEY=votre_cle_secrete_api_ici

# ==========================================
# FONCTIONNALITÉS INTELLIGENTES (IA)
# ==========================================
# Clé d'API pour le regroupement thématique des questions (optionnel si utilisation d'un modèle local comme sentence-transformers)
# Renseigner la clé si utilisation d'Anthropic ou OpenAI
OPENAI_API_KEY=votre_cle_api_openai_ici
ANTHROPIC_API_KEY=votre_cle_api_anthropic_ici

# ==========================================
# CONFIGURATION DU SERVEUR
# ==========================================
ENVIRONMENT=development # Passer à "production" lors du déploiement
HOST=127.0.0.1
PORT=8000
